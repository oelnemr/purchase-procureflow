<odoo>
    <!-- Employee sees only their own.  -->
    <record id="rule_purchase_request_employee" model="ir.rule">
        <field name="name">Purchase Request: Employee Own Records</field>
        <field name="model_id" ref="model_procurement_request" />
        <field name="domain_force"> [('requester_user_id', '=', user.id)] </field>
        <field name="groups" eval="[(4, ref('purchase_procureflow.group_procurement_employee'))]" />
    </record>

    <!-- Manager should see all team requests. -->
    <record id="rule_manager_team" model="ir.rule">
        <field name="name">See All Team Requests</field>
        <field name="model_id" ref="model_procurement_request" />
        <field name="groups" eval="[(4, ref('purchase_procureflow.group_procurement_manager'))]" />
        <field name="domain_force">
            [('manager_id.user_id', '=', user.id)]
        </field>
    </record>

    <!-- Procurement Officer see all requests in the company -->
    <record id="rule_procurement_see_all" model="ir.rule">
        <field name="name">See All Requests</field>
        <field name="model_id" ref="model_procurement_request" />
        <field name="groups" eval="[(4, ref('purchase_procureflow.group_procurement_officer'))]" />
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

</odoo>