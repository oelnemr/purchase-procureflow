<odoo>
    <record id="group_procurement_employee" model="res.groups">
        <field name="name">Procurement Employee</field>
    </record>

    <record id="group_procurement_manager" model="res.groups">
        <field name="name">Procurement Manager</field>
    </record>

    <record id="rule_purchase_request_employee" model="ir.rule">
        <field name="name">Purchase Request: Employee Own Records</field>
        <field name="model_id" ref="model_procurement_request" />
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('purchase_procureflow.group_procurement_employee'))]" />
    </record>
</odoo>