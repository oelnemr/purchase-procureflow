<odoo>

    <record id="module_category_employee_purchase_requisition"
        model="ir.module.category">
        <field name="name">Employee Purchase Requisition</field>
        <field name="sequence">30</field>
        <field name="description">
            Access rights for employee purchase requisition workflow.
        </field>
    </record>

    <!-- GROUPS -->
    <record id="group_procurement_employee" model="res.groups">
        <field name="name">Procurement Employee</field>
        <field name="category_id"
            ref="purchase_procureflow.module_category_employee_purchase_requisition" />
    </record>

    <record id="group_procurement_manager" model="res.groups">
        <field name="name">Procurement Manager</field>
        <field name="category_id"
            ref="purchase_procureflow.module_category_employee_purchase_requisition" />
        <field name="implied_ids" eval="[(4, ref('group_procurement_employee'))]" />
    </record>

    <record id="group_procurement_officer" model="res.groups">
        <field name="name">Procurement Officer</field>
        <field name="category_id"
            ref="purchase_procureflow.module_category_employee_purchase_requisition" />
        <field name="implied_ids" eval="[(4, ref('group_procurement_manager'))]" />
    </record>
</odoo>