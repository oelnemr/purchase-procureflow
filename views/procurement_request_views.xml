<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_procurement_request_tree" model="ir.ui.view">
        <field name="name">view_procurement_request_tree</field>
        <field name="model">procurement.request</field>
        <field name="arch" type="xml">
            <tree string="Request">
                <field name="name" />
                <field name="employee_id" />
                <field name="department_id" readonly="1" />
                <field name="request_date" />
                <field name="total_amount" />
                <field name="status" />
            </tree>
        </field>
    </record>

    <record id="view_procurement_request_form" model="ir.ui.view">
        <field name="name">view_procurement_request_form</field>
        <field name="model">procurement.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="requester_user_id" invisible="1" />
                    <field name="approver_user_id" invisible="1" />

                    <field name="status" widget="statusbar" />
                    <button name="action_submit" type="object" string="Submit Request"
                        class="btn-primary"
                        invisible="status != 'draft' or requester_user_id != uid" />

                    <button name="action_approve" type="object" string="Approve" class="btn-success"
                        invisible="status != 'submitted' or approver_user_id != uid"
                    />

                    <!-- <button name="action_reject" type="object" string=" Reject" class="
                    btn-danger"
                        invisible="status != 'submitted' or approver_user_id != uid"
                    /> -->

                    <button name="%(purchase_procureflow.action_procurement_reject_wizard)d"
                        type="action"
                        string="Reject Request"
                        class="btn-danger"
                        invisible="status != 'submitted' or approver_user_id != uid"
                        context="{'default_request_id': active_id}"
                    />

                    <button name="action_reset_to_draft" type="object" string="Reset To Draft"
                        invisible="status != 'submitted' or requester_user_id != uid"
                    />
                </header>
                <sheet edit="
                    status== 'draft'">
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>

                    <group>

                        <group string="Employee Info">
                            <field name="employee_id" />
                            <field name="manager_id" readonly="1" />
                            <field name="department_id" readonly="1" />
                        </group>

                        <group string="Request Info">
                            <field name="request_date" />
                            <field name="required_date" readonly="status != 'draft'" />
                            <field name="procurement_reason" readonly="status != 'draft'" />
                            <field name="total_amount" />
                            <field name="status" readonly="True" />
                            <field
                                name="rejection_reason"
                                readonly="True"
                                invisible="status not in ['rejected']" />
                        </group>

                        <notebook>
                            <page string="Items">
                                <field name="line_ids" readonly="status != 'draft'">
                                    <tree string="Lines" editable="bottom">
                                        <field name="product_name" string="Product / Item" />
                                        <field name="quantity" string="Quantity" />
                                        <field name="unit_price" />
                                        <field name="subtotal" />
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>
</odoo>