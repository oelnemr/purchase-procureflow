<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="view_procurement_request_tree" model="ir.ui.view">
        <field name="name">view_procurement_request_tree</field>
        <field name="model">procurement.request</field>
        <field name="arch" type="xml">
            <tree string="Request">
                <field name="name" />
                <field name="employee_id" />
                <field name="department_id" readonly="1" />
                <field name="request_date" />
                <field name="total_amount" />
                <field name="status" />
            </tree>
        </field>
    </record>

    <record id="view_procurement_request_form" model="ir.ui.view">
        <field name="name">view_procurement_request_form</field>
        <field name="model">procurement.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>

                    <group>

                        <group string="Employee Info">
                            <field name="employee_id" />
                            <field name="manager_id" readonly="1" />
                            <field name="department_id" readonly="1" />
                        </group>

                        <group string="Request Info">
                            <field name="request_date" />
                            <field name="required_date" />
                            <field name="procurement_reason" />
                            <field name="total_amount" />
                            <field name="status" readonly="True" />
                        </group>

                        <notebook>
                            <page string="Items">
                                <field name="line_ids">
                                    <tree string="Lines" editable="bottom">
                                        <field name="product_name" string="Product / Item" />
                                        <field name="quantity" string="Quantity" />
                                        <field name="unit_price" />
                                        <field name="subtotal" />
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>